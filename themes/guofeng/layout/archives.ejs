<section class="section-container" style="padding-top: 140px;">
  <h2 class="section-title">✦ 文章归档 ✦</h2>
  <p class="section-sub">时光记录，岁月留痕</p>

  <% page.posts.each(function(post){ %>
    <article class="cloud-card" style="margin-bottom: 16px;cursor:pointer;" onclick="location.href='<%- url_for(post.path) %>'">
      <div style="display:flex;justify-content:space-between;align-items:center;flex-wrap:wrap;gap:8px;">
        <div>
          <span style="color:rgba(240,245,242,0.4);font-size:13px;"><%= date(post.date, 'YYYY-MM-DD') %></span>
          <h3 style="margin:4px 0 0;font-size:16px;color:var(--gold-light);"><%= post.title %></h3>
        </div>
        <span style="font-size:12px;color:rgba(201,169,110,0.4);">→</span>
      </div>
    </article>
  <% }) %>
</section>
